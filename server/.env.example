# ===================================================
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ห้าม commit ไฟล์ .env ขึ้น Git
# ===================================================

# Azure AD (จาก App Registration)
CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CLIENT_SECRET=your-client-secret-value

# SharePoint
# วิธีหา: GET https://graph.microsoft.com/v1.0/sites/cpallgroup.sharepoint.com:/sites/MST-PM_CHB
SHAREPOINT_SITE_ID=cpallgroup.sharepoint.com,xxxxxxxx-xxxx,xxxxxxxx-xxxx

# วิธีหา: GET https://graph.microsoft.com/v1.0/sites/{site-id}/drives → หา "Documents"
SHAREPOINT_DRIVE_ID=b!xxxxxxxxxxxxxxxxxxxxxxxx

# Path ของ folder ใน Documents library (เปลี่ยนได้)
BASE_FOLDER=Breakdown Report

# Port ของ server (default 3000)
PORT=3000
